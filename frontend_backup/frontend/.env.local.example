# WebSocket Configuration for Inventory Management System
# Copy this file to .env.local and update with your backend URL

# Backend WebSocket URL
# For local development: ws://localhost:8000/ws/detections
# For Raspberry Pi on same network: ws://192.168.1.100:8000/ws/detections (replace IP)
# For production: wss://your-domain.com/ws/detections
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/detections
